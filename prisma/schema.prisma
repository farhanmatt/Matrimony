// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  NEVER_MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
  AWAITING_DIVORCE
}

enum ProfileStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FamilyType {
  NUCLEAR
  JOINT
  EXTENDED
}

enum FamilyStatus {
  MIDDLE_CLASS
  UPPER_MIDDLE_CLASS
  RICH
  AFFLUENT
}

enum ProfileNotificationKind {
  MESSAGE_REQUEST_REJECTED
}

enum ChatStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Auth / Users ────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  name                  String?
  nameLookup            String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  Role      @default(USER)
  hasSeenDashboardIntro Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  passwordResetRequests PasswordResetRequest[]
  profile               Profile?
  payments              Payment[]
  unlocks               Unlock[]

  @@index([email])
  @@index([nameLookup])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetRequest {
  id                        String    @id @default(cuid())
  userId                    String
  email                     String
  sessionTokenHash          String    @unique
  pendingPasswordHash       String?
  verificationCodeHash      String?
  verificationCodeExpiresAt DateTime?
  verificationAttempts      Int       @default(0)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  expiresAt                 DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model PendingRegistration {
  id                        String   @id @default(cuid())
  email                     String   @unique
  name                      String
  nameLookup                String?
  passwordHash              String
  profile                   Json?
  preference                Json?
  sessionTokenHash          String   @unique
  verificationCodeHash      String
  verificationCodeExpiresAt DateTime
  verificationAttempts      Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  expiresAt                 DateTime

  @@index([email])
  @@index([expiresAt])
}

// ─── Profile ─────────────────────────────────────────────────────────────────

model Profile {
  id            String        @id @default(cuid())
  userId        String        @unique
  profileUserId String?       @unique
  status        ProfileStatus @default(DRAFT)

  // Personal
  fullName               String
  gender                 Gender
  dateOfBirth            DateTime
  height                 Float? // in cm
  nationality            String?
  maritalStatus          MaritalStatus @default(NEVER_MARRIED)
  isPhysicallyChallenged Boolean       @default(false)
  disabilityType         String?
  phone                  String?
  education              String? // Higher education
  course                 String?
  profession             String? // Occupation
  employedIn             String?
  income                 String? // Annual income
  location               String?

  // Address
  houseNumber String?
  streetName  String?
  city        String?
  state       String?
  pincode     String?
  country     String  @default("India")
  bio         String? @db.Text

  // Family
  fatherName        String?
  motherName        String?
  familyType        FamilyType?
  familyStatus      FamilyStatus?
  residentialStatus String?
  siblings          Int?

  // Religious / Cultural
  religion     String?
  caste        String?
  subCaste     String?
  language     String?
  star         String? // Nakshatra
  rasi         String? // Zodiac sign / Rasi
  dosham       String?
  timeOfBirth  String?
  placeOfBirth String?

  // Lifestyle
  diet             String? // Vegetarian/Non-Vegetarian/Vegan
  smoking          String? // Never/Occasionally/Regularly
  drinking         String? // Never/Occasionally/Regularly
  hobbies          String?
  physicalActivity String?
  personalityType  String?
  exercise         String?

  // Profile Photos
  profileImage   String?
  horoscopeImage String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos                ProfilePhoto[]
  preference            Preference?
  likesSent             Like[]                @relation("LikeFrom")
  likesReceived         Like[]                @relation("LikeTo")
  matchesAsA            Match[]               @relation("MatchProfileA")
  matchesAsB            Match[]               @relation("MatchProfileB")
  chatConversationsAsA  ChatConversation[]    @relation("ChatConversationProfileA")
  chatConversationsAsB  ChatConversation[]    @relation("ChatConversationProfileB")
  sentChatMessages      ChatMessage[]         @relation("ChatMessageSender")
  receivedNotifications ProfileNotification[] @relation("ProfileNotificationRecipient")
  authoredNotifications ProfileNotification[] @relation("ProfileNotificationActor")

  @@index([gender])
  @@index([religion])
  @@index([location])
  @@index([caste])
  @@index([status])
  @@index([maritalStatus])
}

model ProfileUserIdSequence {
  gender     String   @id
  nextNumber Int      @default(141)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProfilePhoto {
  id        String   @id @default(cuid())
  profileId String
  url       String
  publicId  String // Cloudinary public ID
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// ─── Preferences ─────────────────────────────────────────────────────────────

model Preference {
  id        String @id @default(cuid())
  profileId String @unique

  ageMin        Int?
  ageMax        Int?
  heightMin     Float?
  heightMax     Float?
  religion      String?
  caste         String?
  education     String?
  profession    String?
  location      String?
  maritalStatus String?
  language      String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ─── Likes & Matches ──────────────────────────────────────────────────────────

model Like {
  id            String   @id @default(cuid())
  fromProfileId String
  toProfileId   String
  createdAt     DateTime @default(now())

  fromProfile Profile @relation("LikeFrom", fields: [fromProfileId], references: [id], onDelete: Cascade)
  toProfile   Profile @relation("LikeTo", fields: [toProfileId], references: [id], onDelete: Cascade)

  @@unique([fromProfileId, toProfileId])
  @@index([fromProfileId])
  @@index([toProfileId])
}

model Match {
  id         String   @id @default(cuid())
  matchCode  String?  @unique
  profileAId String
  profileBId String
  createdAt  DateTime @default(now())

  profileA Profile  @relation("MatchProfileA", fields: [profileAId], references: [id], onDelete: Cascade)
  profileB Profile  @relation("MatchProfileB", fields: [profileBId], references: [id], onDelete: Cascade)
  unlocks  Unlock[]

  @@unique([profileAId, profileBId])
  @@index([profileAId])
  @@index([profileBId])
}

model ChatConversation {
  id                 String     @id @default(cuid())
  profileAId         String
  profileBId         String
  initiatorProfileId String
  status             ChatStatus @default(PENDING)
  lastMessageAt      DateTime   @default(now())
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  profileA Profile       @relation("ChatConversationProfileA", fields: [profileAId], references: [id], onDelete: Cascade)
  profileB Profile       @relation("ChatConversationProfileB", fields: [profileBId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([profileAId, profileBId])
  @@index([profileAId])
  @@index([profileBId])
  @@index([lastMessageAt])
}

model ChatMessage {
  id               String   @id @default(cuid())
  conversationId   String
  senderProfileId  String
  replyToMessageId String?
  content          String   @db.Text
  isRead           Boolean  @default(false)
  isSystemMessage  Boolean  @default(false)
  systemAction     String? // e.g. "REQUEST_ACCEPTED", "REQUEST_REJECTED"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderProfile  Profile          @relation("ChatMessageSender", fields: [senderProfileId], references: [id], onDelete: Cascade)
  replyToMessage ChatMessage?     @relation("ChatMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies        ChatMessage[]    @relation("ChatMessageReplies")

  @@index([conversationId, createdAt])
  @@index([senderProfileId])
  @@index([replyToMessageId])
}

model ProfileNotification {
  id                 String                  @id @default(cuid())
  recipientProfileId String
  actorProfileId     String
  kind               ProfileNotificationKind
  createdAt          DateTime                @default(now())

  recipientProfile Profile @relation("ProfileNotificationRecipient", fields: [recipientProfileId], references: [id], onDelete: Cascade)
  actorProfile     Profile @relation("ProfileNotificationActor", fields: [actorProfileId], references: [id], onDelete: Cascade)

  @@index([recipientProfileId, createdAt])
  @@index([actorProfileId, createdAt])
}

model DeletedMatch {
  id               String   @id @default(cuid())
  matchId          String   @unique
  profileAId       String
  profileBId       String
  profileAName     String
  profileAGender   String
  profileACity     String?
  profileALocation String?
  profileAState    String?
  profileBName     String
  profileBGender   String
  profileBCity     String?
  profileBLocation String?
  profileBState    String?
  unlockCount      Int      @default(0)
  matchCreatedAt   DateTime
  deletedAt        DateTime @default(now())

  @@index([deletedAt])
  @@index([matchId])
}

// ─── Payments & Unlocks ───────────────────────────────────────────────────────

model Payment {
  id                   String   @id @default(cuid())
  userId               String
  matchId              String
  razorpayOrderId      String   @unique
  razorpayPaymentId    String?  @unique
  razorpaySignature    String?
  amount               Int // in paise (₹1 = 100 paise)
  currency             String   @default("INR")
  status               String   @default("CREATED") // CREATED | PAID | FAILED
  baseAmount           Int
  profileAmount        Int
  profileUnlockAmount  Int      @default(500)
  perProfileChatAmount Int      @default(0)
  couponCode           String?
  discountAmount       Int      @default(0) // discount in rupees
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlock Unlock?

  @@index([userId])
  @@index([matchId])
  @@index([razorpayOrderId])
}

enum UnlockType {
  PROFILE
  CHAT
}

model Unlock {
  id        String     @id @default(cuid())
  userId    String
  matchId   String
  paymentId String     @unique
  type      UnlockType @default(PROFILE)
  createdAt DateTime   @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, type])
  @@index([userId])
  @@index([matchId])
}

// ─── Admin Settings ───────────────────────────────────────────────────────────

model AdminSettings {
  id                   String   @id @default("singleton")
  baseAmount           Int      @default(500) // in rupees
  profileAmount        Int      @default(500) // in rupees
  profileUnlockAmount  Int      @default(500) // in rupees
  perProfileChatAmount Int      @default(0) // in rupees
  isChatPaymentEnabled Boolean  @default(true)
  heroImageUrl         String   @default("/main.jpeg")
  logoImageUrl         String   @default("")
  updatedAt            DateTime @updatedAt
}

// ─── Coupon Codes ─────────────────────────────────────────────────────────────

enum CouponFor {
  PROFILE_UNLOCK
  CHAT_UNLOCK
  BOTH
}

model CouponCode {
  id            String    @id @default(cuid())
  code          String    @unique
  couponFor     CouponFor @default(BOTH)
  description   String?
  discountType  String    @default("PERCENTAGE") // PERCENTAGE or FIXED
  discountValue Float // percentage (e.g. 20 = 20%) or fixed amount in rupees
  maxUses       Int? // null = unlimited
  currentUses   Int       @default(0)
  minAmount     Int       @default(0)
  maxDiscount   Int?
  isActive      Boolean   @default(true)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}
